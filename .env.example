PORT=8080
ADMIN_USERNAME=admin
# Optional bootstrap account:
# ADMIN_PASSWORD=replace-with-your-plain-password
# Optional (preferred in production):
# ADMIN_PASSWORD_HASH=scrypt$replace_salt$replace_hash
SESSION_SECRET=replace-with-long-random-secret
SESSION_COOKIE_SECURE=auto
DATA_DIR=/tmp/etf-dashboard-data
# Optional for containers/NAS:
# ADMIN_PASSWORD_HASH_FILE=/run/secrets/admin_password_hash
# SESSION_SECRET_FILE=/run/secrets/session_secret
